<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Edit Task</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen">

<div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md">

<h1 class="text-2xl font-bold mb-6 text-center">Edit Task</h1>

<form action="/edit/<%= task._id %>" method="POST" class="space-y-4">

<input
type="text"
name="task"
value="<%= task.task %>"
class="w-full px-4 py-2 border rounded-lg"
required>

<textarea
name="description"
class="w-full px-4 py-2 border rounded-lg"
required><%= task.description %></textarea>

<button class="w-full bg-green-500 text-white py-2 rounded-lg">
Update Task
</button>

</form>

<a href="/tasks" class="block text-center mt-4 text-blue-500">
Back
</a>

</div>

</body>
</html>