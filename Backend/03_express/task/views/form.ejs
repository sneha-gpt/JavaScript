<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Add Task</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen">

<div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md">

<h1 class="text-2xl font-bold mb-6 text-center">Add Task</h1>

<form action="/add-task" method="POST" class="space-y-4">

<input
type="text"
name="task"
placeholder="Task Name"
class="w-full px-4 py-2 border rounded-lg"
required>

<textarea
name="description"
placeholder="Description"
class="w-full px-4 py-2 border rounded-lg"
required></textarea>

<button class="w-full bg-blue-500 text-white py-2 rounded-lg">
Add Task
</button>

</form>

<a href="/tasks" class="block text-center mt-4 text-blue-500">
View Tasks
</a>

</div>

</body>
</html>